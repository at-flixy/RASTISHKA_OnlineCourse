# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://app:YOUR_DB_PASSWORD@localhost:5432/massage?schema=public"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="https://your-domain.com"

# ─── Initial Admin (used by prisma db seed) ───────────────────────────────────
ADMIN_EMAIL="admin@masalova.com"
ADMIN_PASSWORD="change-this-password"

# ─── GetCourse ────────────────────────────────────────────────────────────────
# Account subdomain: {GETCOURSE_ACCOUNT}.getcourse.ru
GETCOURSE_ACCOUNT="your-account-name"
GETCOURSE_API_KEY=""

# ─── FreedomPay (KG) ──────────────────────────────────────────────────────────
FREEDOMPAY_MERCHANT_ID=""
FREEDOMPAY_SECRET_KEY=""
FREEDOMPAY_TEST_MODE="true"

# ─── YooKassa (RU/СНГ) ────────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
YOOKASSA_TEST_MODE="true"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=""
MAIL_FROM="noreply@your-domain.com"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"
DOMAIN="your-domain.com"

# ─── Production DB ────────────────────────────────────────────────────────────
POSTGRES_PASSWORD="your-strong-db-password"
