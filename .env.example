# Database
DATABASE_URL="postgresql://app:POSTGRES_PASSWORD@postgres:5432/massage?schema=public"

# Auth.js (generate: openssl rand -base64 32)
AUTH_SECRET="your-secret-here"
AUTH_URL="https://your-domain.com"

# Initial admin credentials (used by prisma db seed)
ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PASSWORD="secure-password-here"

# GetCourse
GETCOURSE_ACCOUNT="your-getcourse-subdomain"
GETCOURSE_API_KEY="your-api-key"

# FreedomPay
FREEDOMPAY_MERCHANT_ID="your-merchant-id"
FREEDOMPAY_SECRET_KEY="your-secret-key"
FREEDOMPAY_TEST_MODE="false"

# YooKassa
YOOKASSA_SHOP_ID="your-shop-id"
YOOKASSA_SECRET_KEY="your-secret-key"
YOOKASSA_TEST_MODE="false"

# Email (Resend)
RESEND_API_KEY="re_your_key"
MAIL_FROM="noreply@your-domain.com"

# App
NEXT_PUBLIC_APP_URL="https://your-domain.com"
DOMAIN="your-domain.com"

# PostgreSQL (used in docker-compose.yml)
POSTGRES_PASSWORD="secure-db-password"
