# Database
DATABASE_URL="postgresql://app:YOUR_DB_PASSWORD@localhost:5432/massage?schema=public"

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_TRUST_HOST="true"

# Initial admin (used by prisma db seed)
ADMIN_EMAIL="admin@masalova.com"
ADMIN_PASSWORD="change-this-password"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# GetCourse
# Account subdomain: {GETCOURSE_ACCOUNT}.getcourse.ru
GETCOURSE_ACCOUNT="your-account-name"
GETCOURSE_API_KEY=""

# Email (Resend)
RESEND_API_KEY=""
MAIL_FROM="noreply@your-domain.com"

# App
SITE_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
